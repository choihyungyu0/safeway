APP_ENV=local
CORS_ORIGINS=http://localhost:5174,http://127.0.0.1:5174

# Enable this only when PostgreSQL/PostGIS is running and migrated.
DATABASE_URL=postgresql+psycopg://safeway:safeway@localhost:5432/safeway
USE_DATABASE=false
DB_ECHO=false

# Backend-only secrets. Never expose these through VITE_ frontend variables.
DATA_GO_KR_SERVICE_KEY=
KMA_API_KEY=
AIRKOREA_API_KEY=
REDIS_URL=redis://localhost:6379/0
JWT_SECRET=
